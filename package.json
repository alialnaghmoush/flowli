{
  "name": "flowli",
  "version": "0.1.0",
  "description": "A typed jobs runtime for TypeScript.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ioredis": {
      "types": "./dist/ioredis.d.ts",
      "import": "./dist/ioredis.js"
    },
    "./redis": {
      "types": "./dist/redis.d.ts",
      "import": "./dist/redis.js"
    },
    "./bun-redis": {
      "types": "./dist/bun-redis.d.ts",
      "import": "./dist/bun-redis.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "import": "./dist/runner.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "biome format --write .",
    "lint": "biome check .",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.type-tests.json --noEmit",
    "test": "bun test",
    "verify": "bun run lint && bun run check && bun run build && bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5",
    "valibot": "^1.3.0",
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    },
    "valibot": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
